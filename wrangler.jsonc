{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "astro-outreach-crm",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/server.js",  // ← point to built output, not src
  "assets": {
    "directory": "./dist/client",   // ← serve static client assets
    "binding": "ASSETS"
  }
}
